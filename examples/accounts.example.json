{
  "accounts": [
    {
      "id": "account-a",
      "weight": 2,
      "requests_per_minute": 10,
      "burst": 10,
      "transport": {
        "user_agent": "qveris-account-proxy/account-a",
        "accept_language": "zh-CN,zh;q=0.9",
        "proxy_url_file": "/run/account-secrets/account-a-api-proxy-url"
      },
      "keys": [
        {"id": "primary-2026-07", "api_key": "QVERIS_API_KEY_ACCOUNT_A"}
      ],
      "oauth_tokens": [
        {"id": "primary-2026-07", "access_token": "QVERIS_OAUTH_TOKEN_ACCOUNT_A"}
      ]
    },
    {
      "id": "account-b",
      "weight": 1,
      "requests_per_minute": 10,
      "burst": 10,
      "transport": {
        "user_agent": "qveris-account-proxy/account-b",
        "accept_language": "en-US,en;q=0.9",
        "proxy_url_file": "/run/account-secrets/account-b-api-proxy-url"
      },
      "keys": [
        {"id": "primary-2026-07", "api_key": "QVERIS_API_KEY_ACCOUNT_B"}
      ]
    }
  ]
}
